# Python bytecode / packaging
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
dist/
build/
*.egg

# Test / coverage caches
.pytest_cache/
pytest-cache-files-*/
.cache/
.coverage
.coverage.*
htmlcov/
.tox/
.mypy_cache/
.ruff_cache/

# Virtual environments
.venv/
venv/
env/
.env

# Editors / IDEs
.idea/
.vscode/
.cursor/
.githooks/

# FLIM data files (don't commit large raw datasets)
*.ptu
*.tif
*.tiff

# OS cruft
.DS_Store
Thumbs.db

# Local-only docs
CODEBASE.md

# Sphinx build output
docs/_build/
# Local scratch notes
*.txt
# Committed sample configs only; personal run configs stay local
!examples/
!examples/**/*.sample.txt
examples/headless_gmm.txt
